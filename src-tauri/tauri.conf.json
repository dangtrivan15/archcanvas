{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ArchCanvas",
  "version": "0.1.0",
  "identifier": "com.archcanvas.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "ArchCanvas",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' asset: https://asset.localhost data:"
    }
  },
  "bundle": {
    "externalBin": ["binaries/archcanvas-bridge"]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
