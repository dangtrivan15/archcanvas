{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ArchCanvas",
  "version": "0.7.1",
  "identifier": "com.archcanvas.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "windows": [
      {
        "title": "ArchCanvas",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost ws://127.0.0.1:* http://127.0.0.1:* https://api.anthropic.com https://github.com https://objects.githubusercontent.com; img-src 'self' asset: https://asset.localhost data:"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/archcanvas-bridge"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "git",
          "cmd": "git",
          "args": true
        }
      ]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/dangtrivan15/archcanvas/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4Q0U3MTA4RTQ3QjJCMUUKUldRZUszdmtDSEhPNkgxK0tyemFmSUo4R3NmM3BtZjNwNUZiQW5mSmtoYWZPMzh6MWl0aE9VWVkK"
    }
  }
}
