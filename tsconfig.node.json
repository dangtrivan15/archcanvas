{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "src/core/ai/vitePlugin.ts", "src/core/ai/claudeCodeBridge.ts"]
}
