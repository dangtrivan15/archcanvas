{
  "name": "archcanvas",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:bridge": "vite build --config vite.config.bridge-sidecar.ts",
    "build:sidecar": "bun build --compile src-web/bridge/index.ts --outfile src-tauri/binaries/archcanvas-bridge-aarch64-apple-darwin",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run && npm run test:e2e",
    "test:unit": "vitest run --project unit",
    "test:e2e": "npm run build && npm run test:e2e-no-bridge && npm run test:e2e-bridge",
    "test:e2e-no-bridge": "playwright test --config playwright.config.no-bridge.ts",
    "test:e2e-bridge": "playwright test --config playwright.config.bridge.ts",
    "demo:record": "playwright test --config playwright.config.demo.ts",
    "lint": "eslint src-web/",
    "dev:landing": "vite --config vite.config.landing.ts",
    "build:landing": "tsc --noEmit -p tsconfig.landing.json && vite build --config vite.config.landing.ts",
    "preview:landing": "vite preview --config vite.config.landing.ts",
    "test:e2e-landing": "playwright test --config playwright.config.landing.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/claude-code": "^2.1.74",
    "@anthropic-ai/sdk": "^0.80.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xyflow/react": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "elkjs": "^0.11.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.500.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.7.2",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "ulid": "^3.0.0",
    "yaml": "^2.8.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "happy-dom": "^20.8.4",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "ws": "^8.19.0"
  }
}
