{
  "name": "archcanvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visual architecture design tool with composable, code-bound graph nodes on an interactive canvas",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "proto:generate": "npx pbjs -t static-module -w es6 -o src/proto/archcanvas.pb.js proto/archcanvas.proto && npx pbts -o src/proto/archcanvas.pb.d.ts src/proto/archcanvas.pb.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xyflow/react": "^12.4.0",
    "elkjs": "^0.9.3",
    "html-to-image": "^1.11.11",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.3",
    "protobufjs": "^7.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ulid": "^2.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.49",
    "protobufjs-cli": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
